{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Subscriptor Data Parser",
  "version": "0.1.0",
  "identifier": "com.damiansire.subscriptor",
  "build": {
    "frontendDist": "../app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Subscriptor Data Parser",
        "width": 1100,
        "height": 760,
        "minWidth": 880,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
