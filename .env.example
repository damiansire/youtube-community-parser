# API key de YouTube Data v3.
#
# La app NO la lee de acá: se ingresa en la UI por sesión y vive lo justo en
# memoria (SecretString). Este archivo solo sirve para correr el test de
# integración REAL contra la API, que está `#[ignore]` por defecto:
#
#   YOUTUBE_KEY_API=AIza... cargo test -p sdp-desktop verifica_fetch_real -- --ignored
#
# `.env` está gitignored. No commitees una key viva.
YOUTUBE_KEY_API=''
